export default { async fetch(req, env) { if(!env.CF_API_TOKEN) return new Response(JSON.stringify({error:"no token"}),{status:500}); const z = await (await fetch("https://api.cloudflare.com/client/v4/zones?name=streamlinewebapps.com",{headers:{Authorization:`Bearer ${env.CF_API_TOKEN}`}})).json(); if(!z.success||!z.result||!z.result.length) return new Response(JSON.stringify({step:"zone",result:z},null,2),{status:500,headers:{"Content-Type":"application/json"}}); const zid = z.result[0].id; const patterns = ["streamline.streamlinewebapps.com/*","streamlinewebapps.com/*","www.streamlinewebapps.com/*","lessonlab.streamlinewebapps.com/*","kbt.streamlinewebapps.com/*","family.streamlinewebapps.com/*","support.streamlinewebapps.com/*","school.streamlinewebapps.com/*","likeumm.streamlinewebapps.com/*","chat.streamlinewebapps.com/*"]; const out = []; for(const p of patterns){ const r = await fetch(`https://api.cloudflare.com/client/v4/zones/${zid}/workers/routes`,{method:"POST",headers:{Authorization:`Bearer ${env.CF_API_TOKEN}`,"Content-Type":"application/json"},body:JSON.stringify({pattern:p,script:"streamlinewebapps-proxy"})}); const j = await r.json(); out.push({pattern:p, success:j.success, errors:j.errors, id:j.result?.id}); } return new Response(JSON.stringify({zone:zid, routes:out},null,2),{headers:{"Content-Type":"application/json"}}); } };
